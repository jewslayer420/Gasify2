DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gasify?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Email (SMTP) — use Gmail App Password, Resend, or Mailtrap for dev
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="Gasify <your-email@gmail.com>"

# Germany — Tankerkönig (MTS-K), free key: https://creativecommons.tankerkoenig.de/
TANKERKOENIG_API_KEY="your-tankerkoenig-key"

# Czech Republic + Slovakia — Fuelo.net, free key: https://fuelo.net/about/api_key_request
FUELO_API_KEY="your-fuelo-key"
