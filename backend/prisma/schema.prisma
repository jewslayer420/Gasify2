generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String
  emailVerified  Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  favorites      Favorite[]
  savedLocations SavedLocation[]
  tokens         VerificationToken[]
}

model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Station {
  id           String         @id @default(cuid())
  externalId   String         @unique
  name         String
  brand        String?
  lat          Float
  lng          Float
  address      String?
  city         String
  country      String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  prices       FuelPrice[]
  priceHistory PriceHistory[]
  favorites    Favorite[]
}

// Last completed sync per country (written by bulkUpsertStations, read by the
// freshness monitor to separate "sync dead" from "prices unchanged").
model CountrySyncStatus {
  country    String   @id
  lastSyncAt DateTime
  fetched    Int
}

model FuelPrice {
  id        String   @id @default(cuid())
  stationId String
  fuelType  String
  price     Float
  currency  String   @default("EUR")
  updatedAt DateTime @updatedAt
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, fuelType])
  @@index([fuelType])
}

model PriceHistory {
  id         String   @id @default(cuid())
  stationId  String
  fuelType   String
  price      Float
  recordedAt DateTime @default(now())
  station    Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([stationId, fuelType, recordedAt])
  @@index([recordedAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([userId, stationId])
}

model SavedLocation {
  id        String   @id @default(cuid())
  userId    String
  label     String
  name      String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
