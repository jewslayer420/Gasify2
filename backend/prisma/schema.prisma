generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String? // null for social-login-only accounts
  emailVerified  Boolean             @default(false)
  totpSecret     String? // set at 2FA enrollment; active once totpEnabled
  totpEnabled    Boolean             @default(false)
  emailTwoFactor Boolean             @default(false) // email-code 2FA at login
  backupCodes    String[]            @default([]) // sha256 hex of one-time recovery codes
  googleId       String?             @unique
  role           String              @default("user") // "user" | "admin"
  plan           String              @default("free") // "free" | "premium"
  alertsEnabled  Boolean             @default(false) // price-drop email digests (opt-in)
  lastAlertAt    DateTime? // last digest sent — double-send guard for the daily job
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  favorites      Favorite[]
  savedLocations SavedLocation[]
  tokens         VerificationToken[]
  emailOtps      EmailOtp[]
  trustedDevices TrustedDevice[]
}

// One-time email sign-in codes (email-code 2FA). One active row per user;
// short TTL + attempt cap make online brute force infeasible.
model EmailOtp {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String // sha256(userId:code)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// "Remember this device" — a trusted-device token lets a browser skip the
// email code (the password is still required, so a stolen cookie alone is useless).
model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // sha256(random cookie token)
  label     String? // truncated User-Agent, for a future device list
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Station {
  id           String         @id @default(cuid())
  externalId   String         @unique
  name         String
  brand        String?
  lat          Float
  lng          Float
  address      String?
  city         String
  country      String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  prices       FuelPrice[]
  priceHistory PriceHistory[]
  favorites    Favorite[]
}

// Last completed sync per country (written by bulkUpsertStations, read by the
// freshness monitor to separate "sync dead" from "prices unchanged").
model CountrySyncStatus {
  country    String   @id
  lastSyncAt DateTime
  fetched    Int
}

model FuelPrice {
  id        String   @id @default(cuid())
  stationId String
  fuelType  String
  price     Float
  currency  String   @default("EUR")
  updatedAt DateTime @updatedAt
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, fuelType])
  @@index([fuelType])
}

model PriceHistory {
  id         String   @id @default(cuid())
  stationId  String
  fuelType   String
  price      Float
  recordedAt DateTime @default(now())
  station    Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([stationId, fuelType, recordedAt])
  @@index([recordedAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([userId, stationId])
}

model SavedLocation {
  id        String   @id @default(cuid())
  userId    String
  label     String
  name      String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
